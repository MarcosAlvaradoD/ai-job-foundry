# ============================================================
# AI JOB FOUNDRY - Variables de Entorno
# Copia este archivo a .env y llena tus valores
# NUNCA subas .env al repositorio (ya está en .gitignore)
# ============================================================

# --- Google Sheets ---
GOOGLE_SHEETS_ID=tu_spreadsheet_id_aqui
# Opcional si usas API Key (no OAuth):
GOOGLE_SHEETS_API_KEY=

# --- LinkedIn ---
LINKEDIN_EMAIL=tu_email@gmail.com
LINKEDIN_PASSWORD=tu_password_linkedin

# --- LLM / AI (LM Studio local o API remota) ---
# Para LM Studio local:
LLM_BASE_URL=http://localhost:1234/v1
LLM_URL=http://localhost:1234/v1/chat/completions
LLM_MODEL=lmstudio-community/Meta-Llama-3-8B-Instruct-GGUF

# Para OpenAI:
# OPENAI_API_KEY=sk-...
# LLM_MODEL=gpt-4o-mini

# --- CV (ruta al archivo de CV en texto) ---
CV_FILE=data/cv_descriptor.txt

# --- Alias alternativo para GOOGLE_SHEETS_ID ---
SHEET_ID=tu_spreadsheet_id_aqui
